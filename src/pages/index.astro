const defaultRetailers = (name: string): [string, string][] => [
  ["Amazon", `https://www.amazon.com/s?k=${encodeURIComponent(`${name} jello`)}`],
  ["Whole Foods", `https://www.wholefoodsmarket.com/search?text=${encodeURIComponent(name)}`],
  ["Target", `https://www.target.com/s?searchTerm=${encodeURIComponent(name)}`],
  ["Walmart", `https://www.walmart.com/search?q=${encodeURIComponent(`${name} jello`)}`],
];

const heroCups = products.filter((p) => ["athlet", "recover", "pregame"].includes(p.key));
---

<Base
  title="AthletO performance gelatin"
  description="AthletO: a jello-ish sports snack lineup built on gelatin protein — protein, fiber, electrolytes, probiotics, prebiotics, immune and B-vitamin cups — sweetened only with stevia and erythritol, never sugar."
>
  <main class="jello-page">
    <section class="jello-hero" aria-labelledby="jello-title">
      <div class="hero-copy">
        <a class="brand-lockup" href="/" aria-label="AthletO home">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 64 64" role="presentation" focusable="false">
              <path d="M13 42c0-15 8-29 19-29s19 14 19 29c0 9-7 14-19 14S13 51 13 42Z" fill="#53d86a" stroke="#12323a" stroke-width="4"/>
              <path d="M24 36c0-6 3-12 8-12s8 6 8 12-3 9-8 9-8-3-8-9Z" fill="#f8fbff" stroke="#12323a" stroke-width="4"/>
              <path d="M20 15c4 6 20 6 24 0" fill="none" stroke="#12323a" stroke-width="4" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="brand-name wordmark">Athlet<span class="o">O</span></span>
        </a>
        <p class="eyebrow">Performance gelatin cups</p>
        <h1 id="jello-title">Wobble hard. Recover clean.</h1>
        <p class="lede">A jello-ish sports snack built on gelatin protein — fiber, vitamin C, electrolytes, probiotics, and B vitamins, sweetened only with stevia and erythritol. Never sugar.</p>
        <div class="hero-actions" aria-label="AthletO page links">
          <a href="#products">Shop the lineup</a>
          <a href="#formula">See the formula</a>
        </div>
      </div>
      <div class="hero-stage" aria-label="AthletO product lineup">
        <div class="shelf">
          {heroCups.map((product) => (
            <div class="hero-pack" aria-hidden="true">
              <CupVisual sub={product.sub} cup={product.cup} uid={`hero-${product.key}`} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="jello-section" id="products" aria-labelledby="products-title">
      <div class="section-heading">
        <h2 id="products-title">Ten cups, ten locker-room jobs.</h2>
        <p>Gelatin gives every cup its bounce and protein base. From there each cup stacks one job — protein, fiber, minerals, cultures, or vitamins — and none of them stack sugar.</p>
      </div>
      <div class="product-line">
        {products.map((product) => (
          <article class={`product-card ${product.key}`}>
            <div class="product-visual" aria-hidden="true" style={`--visual-bg: ${product.visualBg};`}>
              <span class="cal-chip">{product.calories} cal</span>
              <CupVisual sub={product.sub} cup={product.cup} uid={`card-${product.key}`} />
              <PacketVisual sub={product.sub} body={product.cup.body} accent={product.cup.accent} uid={`card-${product.key}`} />
            </div>
            <div class="product-copy">
              <p class="product-kicker">{product.kicker}</p>
              <h3 class="product-name">
                <span class="wordmark">Athlet<span class="o">O</span></span>
                <span class="product-sub">{product.sub}</span>
              </h3>
              <p class="tagline">{product.tagline}</p>
              <div class="format-row" aria-label={`AthletO ${product.sub} formats`}>
                <div class="format">
                  <b>Ready cup</b>
                  <span>Pre-dosed cup — just add cold water, stir, chill.</span>
                  <span class="format-cal">{product.calories} cal</span>
                </div>
                <div class="format">
                  <b>Powder packet</b>
                  <span>Single-serve packet — pour into your own cup.</span>
                  <span class="format-cal">{product.calories} cal</span>
                </div>
              </div>
              <ul class="benefits" aria-label={`AthletO ${product.sub} benefits`}>
                {product.benefits.map((benefit) => (
                  <li>{benefit}</li>
                ))}
              </ul>
              <div class="ingredients">
                <p class="ingredients-title">Ingredients</p>
                <p class="ingredients-list">{product.ingredients.join(", ")}. <b>No added sugar.</b></p>
              </div>
              <div class="retailer-row" aria-label={`AthletO ${product.sub} retailer links`}>
                {(product.retailers ?? defaultRetailers(`AthletO ${product.sub}`)).map(([label, href]) => (
                  <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
      <p class="store-note">Retail links open retailer searches for this concept lineup.</p>
    </section>

    <section class="jello-section sweetener-band" aria-labelledby="sweetener-title">
      <div>
        <h2 id="sweetener-title">Sweetened with stevia + erythritol. Never sugar.</h2>
        <p>Every cup in the lineup is sugar-free. The sweetness comes only from stevia leaf extract and erythritol — no cane sugar, no corn syrup, no juice-concentrate loopholes. The wobble is the treat; the sugar crash stays home.</p>
      </div>
      <div class="sweetener-chips" aria-label="Sweetener facts">
        <span>Stevia leaf extract</span>
        <span>Erythritol</span>
        <span>0g added sugar</span>
        <span>No corn syrup</span>
        <span>No juice concentrate</span>
      </div>
    </section>

    <section class="jello-section sampler-band" aria-labelledby="sampler-title">
      <div class="sampler-copy">
        <h2 id="sampler-title">Build a snack-table sample pack.</h2>
        <p>Pick the cup for the moment and the flavor brief lands ready for the sideline cooler.</p>
      </div>
      <div class="sampler-panel">
        <div class="sampler-controls" aria-label="Sample pack choices">
          {products.map((product, index) => (
            <button type="button" data-sample={product.key} aria-pressed={index === 0 ? "true" : "false"}>{product.sub}</button>
          ))}
        </div>
        <div id="sampler-result" class="sampler-result" aria-live="polite">
          {products.map((product, index) => (
            <div class={`sample-card ${product.key}`} style={`--sample-color: ${product.cup.accent};`} data-sample-card={product.key} hidden={index !== 0}>
              <div class="sample-badge">{product.badge}</div>
              <div>
                <p class="sample-sub">Athlet<span class="o-inline">O</span> · {product.sub}</p>
                <h3>{product.sampleTitle}</h3>
                <p>{product.sampleCopy}</p>
                <div class="sample-stack">
                  {product.benefits.slice(0, 4).map((chip) => (
                    <span>{chip}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="jello-section formula-band" id="formula" aria-labelledby="formula-title">
      <div>
        <h2 id="formula-title">Built like a sports drink moved into a snack cup.</h2>
        <p>Each concept cup starts with a bouncy gelatin base, then stacks athlete-friendly add-ins without the syrupy sugar crash.</p>
      </div>
      <div class="formula-grid">
        <div class="formula-tile"><b>Protein bounce</b><span>Gelatin gives the signature wobble and a compact protein payload.</span></div>
        <div class="formula-tile"><b>Complete when it counts</b><span>Gelatin is an incomplete protein, so the protein cup adds the missing essential amino acids — tryptophan, methionine, cysteine, and BCAAs.</span></div>
        <div class="formula-tile"><b>Fiber assist</b><span>Inulin leads, and the fiber cup stacks psyllium, acacia, resistant dextrin, and pectin on top.</span></div>
        <div class="formula-tile"><b>Hydration salts</b><span>Sodium, potassium, and magnesium help the cup earn its gym-bag spot.</span></div>
        <div class="formula-tile"><b>Bright support</b><span>Vitamin C, zinc, B vitamins, and probiotic cultures round out the everyday performance stack.</span></div>
        <div class="formula-tile"><b>Sweetness without sugar</b><span>Stevia leaf extract and erythritol only — never cane sugar, corn syrup, or juice concentrate.</span></div>
      </div>
    </section>
  </main>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-sample]");
    const cards = document.querySelectorAll<HTMLElement>("[data-sample-card]");
    for (const button of buttons) {
      button.addEventListener("click", () => {
        const selected = button.dataset.sample;
        for (const other of buttons) {
          other.setAttribute("aria-pressed", String(other === button));
        }
        for (const card of cards) {
          card.hidden = card.dataset.sampleCard !== selected;
        }
      });
    }
  </script>
</Base>
